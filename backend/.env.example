# Backend environment variables
# Copy to .env for local development

# Telegram bot token from @BotFather
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff

# URL вашего задеплоенного frontend (для ссылок в боте)
WEB_APP_URL=https://your-app.netlify.app

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skinemsia?sslmode=disable

# Random secret for signing (32+ chars)
APP_SECRET=change_me_to_a_random_secret_string

# Server port
PORT=8080

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Environment: development | production
APP_ENV=development
